{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "ll *": "allow",
      "pwd *": "allow",
      "cd *": "allow",
      "tree *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "gstat *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "which *": "allow",
      "command *": "allow",
      "uname *": "allow",
      "hostname *": "allow",
      "whoami *": "allow",
      "id *": "allow",
      "cat *": "allow",
      "nl *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "wc *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "gfind *": "allow",
      "parallel *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "pkill *": "allow",
      "top *": "allow",
      "htop *": "allow",
      "test *": "allow",
      "[ *": "allow",
      "source *": "allow",
      "chmod *": "allow",
      "xargs *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "gawk *": "allow",
      "sed *": "allow",
      "gsed *": "allow",
      "diff *": "allow",
      "cmp *": "allow",
      "open *": "allow",
      "pbcopy *": "allow",
      "pbpaste *": "allow",
      "mdls *": "allow",
      "defaults *": "allow",
      "launchctl *": "allow",
      "dtruss *": "allow",
      "lsof *": "allow",
      "vm_stat *": "allow",
      "sysctl *": "allow",
      "networksetup *": "allow",
      "scutil *": "allow",
      "jj *": "allow",
      "pnpm *": "allow",
      "bun *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "zig *": "allow",
      "node *": "allow",
      "mise *": "allow",
      "brew *": "allow",
      "zed *": "allow",
      "claude *": "allow",
      "kilo *": "allow",
      "opencode *": "allow",
      "amp *": "allow",
      "codex *": "allow",
      "rustc *": "allow",
      "terraform *": "allow",
      "ansible-playbook *": "allow",
      "helm *": "allow",
      "docker *": "allow",
      "kubectl *": "allow",
      "ssh *": "allow",
      "curl *": "allow",
      "pyenv *": "allow",
      "uv *": "allow",
      "python3 *": "allow",
      "python *": "allow",
      "sips *": "allow",
      "imageoptim *": "allow",
      "trash *": "allow",
      "tmux *": "allow",
      "gh *": "allow",
      "glab *": "allow",
      "pass-cli *": "allow",
      "axe *": "allow",
      "oracle *": "allow",
      "npx *": "allow",
      "bunx *": "allow",
      "stagehand *": "allow",
      "playwright *": "allow",
      "xcrun *": "allow",
      "simctl *": "allow"
    }
  },
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "mcp": {
    "context7": {
      "command": ["npx", "@upstash/context7-mcp@latest"],
      "type": "local"
    },
    "lightpanda": {
      "command": ["npx", "lightpanda-mcp@latest"],
      "environment": {
        "LIGHTPANDA_PATH": "{env:HOME}/bin/lightpanda"
      },
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3-coder-next:cloud": {
          "name": "qwen3-coder-next:cloud"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "{env:OLLAMA_CLOUD_API_KEY}"
      }
    },
    "fireworks": {
      "name": "Fireworks AI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.fireworks.ai/inference/v1",
        "apiKey": "{env:FIREWORKS_API_KEY}"
      },
      "models": {
        "accounts/fireworks/models/glm-5p1": {
          "name": "GLM 5.1"
        },
        "accounts/fireworks/models/kimi-k2p6": {
          "name": "Kimi K2.6"
        },
        "accounts/fireworks/models/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        }
      }
    },
    "openrouter": {
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "moonshotai/kimi-k2.5": {
          "name": "Kimi K2.5 (OR)"
        }
      }
    },
    "moonshot": {
      "name": "Moonshot",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.moonshot.com/v1",
        "apiKey": "{env:MOONSHOT_API_KEY}"
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      }
    },
    "pioneer": {
      "name": "Pioneer",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.pioneer.ai/v1",
        "apiKey": "{env:PIONEER_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7"
        }
      }
    }
  }
}
