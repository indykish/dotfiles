#!/usr/bin/env bash
# link-agents-md — link AGENTS.md rules, dispatch files, audits, and agent home instructions.

set -uo pipefail

DOTFILES="$HOME/Projects/dotfiles"

ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }
fail() { printf '\033[31m✘\033[0m %s\n' "$1" >&2; }

case "${1:-}" in
  -h|--help) echo "link-agents-md — link AGENTS.md rules, dispatch files, audits, and agent home instructions."; echo "Usage: link-agents-md [--list] [--no-prune] [--doctor]"; exit 0 ;;
esac

# Project-repo manifest. Format: `<source-rel-to-dotfiles>:<target-rel-to-repo>`.
PROJECT_LINKS=(
  "AGENTS.md:AGENTS.md"
  "audits/agents-md.md:audits/agents-md.md"
  "docs/TEMPLATE.md:docs/TEMPLATE.md"
  "docs/REST_API_DESIGN_GUIDELINES.md:docs/REST_API_DESIGN_GUIDELINES.md"
  "docs/SCHEMA_CONVENTIONS.md:docs/SCHEMA_CONVENTIONS.md"
  "docs/LOGGING_STANDARD.md:docs/LOGGING_STANDARD.md"
  "docs/LIFECYCLE_PATTERNS.md:docs/LIFECYCLE_PATTERNS.md"
  "docs/CHANGELOG_VOICE.md:docs/CHANGELOG_VOICE.md"
  "docs/DOCUMENTATION_RULES.md:docs/DOCUMENTATION_RULES.md"
  "docs/EXECUTE_DOC_READS.md:docs/EXECUTE_DOC_READS.md"
  "docs/VERIFY_TIERS.md:docs/VERIFY_TIERS.md"
  "docs/HARNESS_VERIFY_OUTPUT.md:docs/HARNESS_VERIFY_OUTPUT.md"
  "docs/greptile-learnings:docs/greptile-learnings"
  "dispatch:dispatch"
  "audits/spec-template.sh:audits/spec-template.sh"
  "audits/ufs.sh:audits/ufs.sh"
  "audits/logging.sh:audits/logging.sh"
  "audits/design-tokens.sh:audits/design-tokens.sh"
  "audits/deinit-pairs.sh:audits/deinit-pairs.sh"
  "audits/error-codes.sh:audits/error-codes.sh"
  "audits/cross-tier-rates.sh:audits/cross-tier-rates.sh"
  "audits/msid-ui.sh:audits/msid-ui.sh"
)

# Project repos. Override with: KISHORES_TARGETS="path1 path2 ..." link-agents-md.
_KISHORES_TARGETS_ENV="${KISHORES_TARGETS:-}"
KISHORES_TARGETS=(
  "$HOME/Projects/agentsfleet"
  "$HOME/Projects/cache-kit.rs"
)
if [[ -n "$_KISHORES_TARGETS_ENV" ]]; then
  read -ra KISHORES_TARGETS <<< "$_KISHORES_TARGETS_ENV"
fi
unset _KISHORES_TARGETS_ENV

# Agent home-dir manifest. Format: `<source-rel-to-dotfiles>:<absolute-target>`.
AGENT_HOME_LINKS=(
  "AGENTS.md:$HOME/.claude/CLAUDE.md"
  "AGENTS.md:$HOME/.codex/AGENTS.md"
  "AGENTS.md:$HOME/.opencode/AGENTS.md"
  "AGENTS.md:$HOME/.amp/AGENTS.md"
)

# Flag parsing. PRUNE defaults on; --doctor verifies state without changing it.
PRUNE=1
DOCTOR_ONLY=0
_args=()
for _a in ${@+"$@"}; do
  case "$_a" in
    --no-prune) PRUNE=0 ;;
    --doctor) DOCTOR_ONLY=1 ;;
    *) _args+=("$_a") ;;
  esac
done
set -- ${_args[@]+"${_args[@]}"}
unset _a _args

if [[ "${1:-}" == "--list" ]]; then
  echo "Project-repo manifest (sources in $DOTFILES):"
  for link in "${PROJECT_LINKS[@]}"; do echo "  ${link%%:*}"; done
  echo
  echo "Project-repo targets (KISHORES_TARGETS):"
  for t in "${KISHORES_TARGETS[@]}"; do echo "  $t"; done
  echo
  echo "Agent home-dir links:"
  for link in "${AGENT_HOME_LINKS[@]}"; do echo "  ${link%%:*}  →  ${link#*:}"; done
  echo
  echo "Prune: dangling symlinks into $DOTFILES are removed from project repos (--no-prune to disable)."
  exit 0
fi

[[ -d "$DOTFILES" ]] || { fail "$DOTFILES not found"; exit 1; }

LINKED=0
RETARGETED=0
PRUNED=0
SKIPPED=0
FAILED=0

# Resolve a path without requiring GNU readlink. Used only for comparing
# symlink destinations, so relative links that point at the right dotfiles
# source are left alone instead of being churned into absolute links.
canonical_path() {
  local path="$1"
  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  (cd -P "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base")
}

link_target_path() {
  local link_path="$1"
  local target="$2"

  if [[ "$target" = /* ]]; then
    canonical_path "$target"
  else
    canonical_path "$(dirname "$link_path")/$target"
  fi
}

# Helper: idempotently create one symlink, updating counters.
make_link() {
  local src_full="$1"
  local dst_full="$2"
  local label="$3"

  if [[ ! -e "$src_full" ]]; then
    warn "  source missing in dotfiles, skip: ${src_full#$DOTFILES/}"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  mkdir -p "$(dirname "$dst_full")"

  if [[ -L "$dst_full" ]]; then
    local cur cur_resolved src_resolved
    cur=$(readlink "$dst_full")
    cur_resolved=$(link_target_path "$dst_full" "$cur" || true)
    src_resolved=$(canonical_path "$src_full")
    if [[ "$cur_resolved" = "$src_resolved" ]]; then
      return  # already correct, silent
    fi
    warn "  retarget: $label was → $cur"
    rm "$dst_full"
    if ln -s "$src_full" "$dst_full"; then
      ok "  $label → $src_full"
      RETARGETED=$((RETARGETED + 1))
    else
      fail "  ln failed: $label"
      FAILED=$((FAILED + 1))
    fi
    return
  fi

  if [[ -e "$dst_full" ]]; then
    warn "  skip: $label exists as real file/dir (would overwrite)"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  if ln -s "$src_full" "$dst_full"; then
    ok "  $label → $src_full"
    LINKED=$((LINKED + 1))
  else
    fail "  ln failed: $label"
    FAILED=$((FAILED + 1))
  fi
}

doctor_link() {
  local src_full="$1" dst_full="$2" label="$3"
  local cur cur_resolved src_resolved

  if [[ ! -L "$dst_full" ]]; then
    fail "  doctor: $label is not a symlink"
    FAILED=$((FAILED + 1))
    return
  fi

  cur=$(readlink "$dst_full")
  cur_resolved=$(link_target_path "$dst_full" "$cur" || true)
  src_resolved=$(canonical_path "$src_full")
  if [[ "$cur_resolved" = "$src_resolved" ]]; then
    ok "  doctor: $label → $src_full"
  else
    fail "  doctor: $label points to $cur, expected $src_full"
    FAILED=$((FAILED + 1))
  fi
}

# ---------------------------------------------------------------------------
# Helper: expand a project target into the set of paths to link into.
#   Includes the target itself + every linked git worktree of the same
#   repo. Worktrees are common in our flow (one per active milestone);
#   without this, in-progress branches miss new dotfiles symlinks until
#   the PR merges.
#   Skips bare/missing/locked worktrees and silently degrades when the
#   target isn't a git repo (treats it as a single path).
# ---------------------------------------------------------------------------
expand_worktrees() {
  local repo="$1"
  if [[ ! -d "$repo/.git" && ! -f "$repo/.git" ]]; then
    printf '%s\n' "$repo"
    return
  fi
  local listed
  listed=$(git -C "$repo" worktree list --porcelain 2>/dev/null) || {
    printf '%s\n' "$repo"
    return
  }
  awk '
    /^worktree / { wt=$2; bare=0; locked=0; next }
    /^bare/ { bare=1; next }
    /^locked/ { locked=1; next }
    /^$/ {
      if (wt && !bare && !locked) print wt
      wt=""; bare=0; locked=0
    }
    END {
      if (wt && !bare && !locked) print wt
    }
  ' <<<"$listed"
}

# ---------------------------------------------------------------------------
# Helper: collapse '.'/'..' segments in an absolute path textually. No
# filesystem access — works even when the target was deleted (realpath would
# fail). String-built, no arrays, so it's safe under macOS bash 3.2 + `set -u`.
# ---------------------------------------------------------------------------
normalize_path() {
  local part result="" IFS=/
  for part in $1; do
    case "$part" in
      ''|.) ;;
      ..)   result="${result%/*}" ;;
      *)    result="$result/$part" ;;
    esac
  done
  printf '%s\n' "${result:-/}"
}

# ---------------------------------------------------------------------------
# Helper: prune orphaned symlinks under a repo — links that are dangling AND
# point into $DOTFILES (a manifest entry whose source was deleted/renamed).
# Filesystem-only: the removal becomes a staged deletion on the repo's next
# `git add -A`, just like an added link awaits commit. Skips .git/node_modules/
# .zig-cache; never touches valid links or links pointing outside $DOTFILES.
# ---------------------------------------------------------------------------
prune_orphans() {
  local root="$1" link tgt abs
  while IFS= read -r link; do
    [[ -e "$link" ]] && continue          # target resolves → not an orphan
    tgt=$(readlink "$link") || continue
    [[ "$tgt" = /* ]] || tgt="$(dirname "$link")/$tgt"
    abs=$(normalize_path "$tgt")
    case "$abs" in
      "$DOTFILES"/*|"$DOTFILES")
        if rm "$link"; then
          warn "  pruned orphan: ${link#$root/} ↛ $tgt"
          PRUNED=$((PRUNED + 1))
        else
          fail "  rm failed: $link"
          FAILED=$((FAILED + 1))
        fi
        ;;
    esac
  done < <(find "$root" -type l \
             -not -path '*/.git/*' \
             -not -path '*/node_modules/*' \
             -not -path '*/.zig-cache/*' 2>/dev/null)
}

doctor_links() {
  local repo wt link src dst
  for repo in "${KISHORES_TARGETS[@]}"; do
    [[ -d "$repo" ]] || { warn "doctor: skip missing target $repo"; continue; }
    while IFS= read -r wt; do
      [[ -z "$wt" || ! -d "$wt" ]] && continue
      info "Doctor: $wt"
      for link in "${PROJECT_LINKS[@]}"; do
        src="${link%%:*}"
        dst="${link#*:}"
        doctor_link "$DOTFILES/$src" "$wt/$dst" "$dst"
      done
    done < <(expand_worktrees "$repo")
  done

  echo
  info "Doctor: agent home dirs"
  for link in "${AGENT_HOME_LINKS[@]}"; do
    src="${link%%:*}"
    dst="${link#*:}"
    [[ -d "$(dirname "$dst")" ]] || { info "  skip ${dst#$HOME/} (agent not installed)"; continue; }
    doctor_link "$DOTFILES/$src" "$dst" "${dst#$HOME/}"
  done
}

if [[ $DOCTOR_ONLY -eq 1 ]]; then
  doctor_links
  [[ $FAILED -eq 0 ]] && ok "agents doctor passed" || { fail "agents doctor failed"; exit 1; }
  exit 0
fi

# ---------------------------------------------------------------------------
# Pass 1: project repos (expanded across worktrees).
# ---------------------------------------------------------------------------
for repo in "${KISHORES_TARGETS[@]}"; do
  if [[ ! -d "$repo" ]]; then
    warn "skip target — not a directory: $repo"
    continue
  fi
  while IFS= read -r wt; do
    [[ -z "$wt" ]] && continue
    [[ ! -d "$wt" ]] && { warn "skip worktree — not a directory: $wt"; continue; }
    if [[ "$wt" = "$repo" ]]; then
      info "→ $wt"
    else
      info "→ $wt (worktree of $repo)"
    fi
    for link in "${PROJECT_LINKS[@]}"; do
      src="${link%%:*}"
      dst="${link#*:}"
      make_link "$DOTFILES/$src" "$wt/$dst" "$dst"
    done
    [[ $PRUNE -eq 1 ]] && prune_orphans "$wt"
  done < <(expand_worktrees "$repo")
done

# ---------------------------------------------------------------------------
# Pass 2: agent home dirs.
# ---------------------------------------------------------------------------
echo
info "→ agent home dirs"
for link in "${AGENT_HOME_LINKS[@]}"; do
  src="${link%%:*}"
  dst="${link#*:}"
  if [[ ! -d "$(dirname "$dst")" ]]; then
    info "  skip ${dst#$HOME/} (agent not installed)"
    continue
  fi
  make_link "$DOTFILES/$src" "$dst" "${dst#$HOME/}"
done

echo
echo "summary: linked=$LINKED retargeted=$RETARGETED pruned=$PRUNED skipped=$SKIPPED failed=$FAILED"
[[ $FAILED -eq 0 ]] || { fail "some links failed"; exit 1; }
echo
doctor_links
[[ $FAILED -eq 0 ]] && ok "agents links complete" || { fail "agents doctor failed"; exit 1; }
