#!/usr/bin/env bash
set -euo pipefail

# Colors
ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }

usage() {
  cat <<'EOF'
update-ai-tools — update Artificial Intelligence (AI) coding command-line tools,
then relink local dotfiles, update skills, and refresh global agent instructions.

Usage: update-ai-tools [--doctor]

Runs tool updaters for: claude, opencode, amp, and @openai/codex.
Then runs `link-bin-dotfiles` and `update-skills`, followed by repository rules
status. Each delegate runs its own postflight check before this script exits.
--doctor verifies delegate state without updating tools.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  --doctor)
    ~/bin/link-bin-dotfiles --doctor
    ~/bin/update-skills --doctor
    ~/bin/orly doctor --all
    exit 0
    ;;
esac

info "🤖 Updating Artificial Intelligence (AI) coding tools..."

# Upgrade each tool if installed
if command -v claude &>/dev/null; then
    info "Upgrading claude..."
    claude upgrade || warn "Claude upgrade failed"
fi

if command -v opencode &>/dev/null; then
    info "Upgrading opencode..."
    opencode upgrade || warn "Opencode upgrade failed"
fi

if command -v amp &>/dev/null; then
    info "Upgrading amp..."
    amp update || warn "Amp update failed"
fi

if command -v codex &>/dev/null || npm list -g @openai/codex &>/dev/null; then
    info "Upgrading @openai/codex..."
    npm install -g @openai/codex || warn "Codex upgrade failed"
fi

ok "All AI coding tools updated!"

echo ""
info "🔗 Running link-bin-dotfiles to link personal dotfiles and helper commands..."
if [[ -x "$HOME/bin/link-bin-dotfiles" ]]; then
  ~/bin/link-bin-dotfiles
else
  "$HOME/Projects/dotfiles/bin/link-bin-dotfiles"
fi

echo ""
info "🔄 Running update-skills to keep skills updated..."
~/bin/update-skills

echo ""
info "🔎 Reporting repository rules snapshot status..."
if [[ -x "$HOME/bin/orly" ]]; then
  ~/bin/orly doctor --all
else
  warn "orly not found in ~/bin/ — run link-bin-dotfiles first"
fi
