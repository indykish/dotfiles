#!/usr/bin/env bash
set -euo pipefail

# Colors
ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }

info "🤖 Upgrading AI coding tools..."

# Upgrade each tool if installed
if command -v claude &>/dev/null; then
    info "Upgrading claude..."
    claude upgrade || warn "Claude upgrade failed"
fi

if command -v opencode &>/dev/null; then
    info "Upgrading opencode..."
    opencode upgrade || warn "Opencode upgrade failed"
fi

if command -v amp &>/dev/null; then
    info "Upgrading amp..."
    amp update || warn "Amp update failed"
fi

if command -v codex &>/dev/null || npm list -g @openai/codex &>/dev/null; then
    info "Upgrading @openai/codex..."
    npm install -g @openai/codex || warn "Codex upgrade failed"
fi

ok "All AI coding tools upgraded!"

echo ""
info "🔄 Running sync-skills to keep skills updated..."
~/bin/sync-skills

echo ""
info "🔗 Running sync-agents-contract to symlink AGENTS.md contract into project repos..."
if [[ -x "$HOME/bin/sync-agents-contract" ]]; then
  ~/bin/sync-agents-contract
else
  warn "sync-agents-contract not found in ~/bin/ — copy from dotfiles/bin/ to enable"
fi
