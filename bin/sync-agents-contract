#!/usr/bin/env bash
# sync-agents-contract — symlink the AGENTS.md contract from
# ~/Projects/dotfiles into every calling project repo.
#
# Run after pulling new dotfiles changes that add or rename a contract file
# (gate body, rules doc, questionnaire). Idempotent — re-running is safe.
#
# Manifest below names every file/dir to propagate. Adding a new entry is
# the only edit required when a new contract file lands.
#
# Skip rule: if a target already exists as a real file/dir (NOT a symlink),
# the script warns and skips it — never clobbers project-local content.

set -uo pipefail

DOTFILES="$HOME/Projects/dotfiles"

ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }
fail() { printf '\033[31m✘\033[0m %s\n' "$1" >&2; }

# Manifest — `<source-rel-to-dotfiles>:<target-rel-to-repo>`.
# Add a line here when a new contract file is introduced.
LINKS=(
  "AGENTS.md:AGENTS.md"
  "AGENTS_INVARIANCE.md:AGENTS_INVARIANCE.md"
  "docs/TEMPLATE.md:docs/TEMPLATE.md"
  "docs/REST_API_DESIGN_GUIDELINES.md:docs/REST_API_DESIGN_GUIDELINES.md"
  "docs/SCHEMA_CONVENTIONS.md:docs/SCHEMA_CONVENTIONS.md"
  "docs/ZIG_RULES.md:docs/ZIG_RULES.md"
  "docs/ZIG_STATIC_OPENSSL.md:docs/ZIG_STATIC_OPENSSL.md"
  "docs/BUN_RULES.md:docs/BUN_RULES.md"
  "docs/greptile-learnings:docs/greptile-learnings"
  "docs/gates:docs/gates"
)

# Calling repos — every project that already symlinks AGENTS.md.
# Override with: SYNC_AGENTS_TARGETS="path1 path2 ..." sync-agents-contract
DEFAULT_TARGETS=(
  "$HOME/Projects/usezombie"
)

if [[ -n "${SYNC_AGENTS_TARGETS:-}" ]]; then
  read -ra TARGETS <<< "$SYNC_AGENTS_TARGETS"
else
  TARGETS=("${DEFAULT_TARGETS[@]}")
fi

if [[ "${1:-}" == "--list" ]]; then
  echo "Sources (in $DOTFILES):"
  for link in "${LINKS[@]}"; do echo "  ${link%%:*}"; done
  echo
  echo "Targets:"
  for t in "${TARGETS[@]}"; do echo "  $t"; done
  exit 0
fi

[[ -d "$DOTFILES" ]] || { fail "$DOTFILES not found"; exit 1; }

LINKED=0
RETARGETED=0
SKIPPED=0
FAILED=0

for repo in "${TARGETS[@]}"; do
  if [[ ! -d "$repo" ]]; then
    warn "skip target — not a directory: $repo"
    continue
  fi

  info "→ $repo"

  for link in "${LINKS[@]}"; do
    src="${link%%:*}"
    dst="${link#*:}"
    src_full="$DOTFILES/$src"
    dst_full="$repo/$dst"

    if [[ ! -e "$src_full" ]]; then
      warn "  source missing in dotfiles, skip: $src"
      ((SKIPPED++)) || true
      continue
    fi

    mkdir -p "$(dirname "$dst_full")"

    if [[ -L "$dst_full" ]]; then
      cur=$(readlink "$dst_full")
      if [[ "$cur" = "$src_full" ]]; then
        # already correctly linked — no output, idempotent
        continue
      else
        warn "  retarget: $dst was → $cur"
        rm "$dst_full"
        ln -s "$src_full" "$dst_full" && { ok "  $dst → $src_full"; ((RETARGETED++)) || true; } \
                                       || { fail "  ln failed: $dst";  ((FAILED++)) || true; }
        continue
      fi
    elif [[ -e "$dst_full" ]]; then
      warn "  skip: $dst exists as real file/dir (would clobber)"
      ((SKIPPED++)) || true
      continue
    fi

    if ln -s "$src_full" "$dst_full"; then
      ok "  $dst → $src_full"
      ((LINKED++)) || true
    else
      fail "  ln failed: $dst"
      ((FAILED++)) || true
    fi
  done
done

echo
echo "summary: linked=$LINKED retargeted=$RETARGETED skipped=$SKIPPED failed=$FAILED"
[[ $FAILED -eq 0 ]] && ok "agents contract sync complete" || { fail "some links failed"; exit 1; }
