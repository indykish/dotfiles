#!/usr/bin/env bash
# link-bin-dotfiles — link personal dotfiles and helper commands into $HOME.
set -euo pipefail

DOTFILES="$HOME/Projects/dotfiles"

ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }
fail() { printf '\033[31m✘\033[0m %s\n' "$1" >&2; }

usage() {
  cat <<'EOF'
link-bin-dotfiles — link home dotfiles and helper commands from ~/Projects/dotfiles.

Links:
  ~/.tmux.conf
  ~/bin/link-bin-dotfiles
  ~/bin/link-agents-md
  ~/bin/update-skills
  ~/bin/provision-env-1password
  ~/bin/update-ai-tools

Also removes old ~/bin/sync-* and ~/bin/upgrade-ai-tools links when they point
back into this dotfiles repo.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
esac

LINKED=0
RETARGETED=0
SKIPPED=0
REMOVED=0
FAILED=0

DOTFILE_LINKS=(
  ".tmux.conf:$HOME/.tmux.conf"
)

BIN_LINKS=(
  "bin/link-bin-dotfiles:$HOME/bin/link-bin-dotfiles"
  "bin/link-agents-md:$HOME/bin/link-agents-md"
  "bin/update-skills:$HOME/bin/update-skills"
  "bin/provision-env-1password:$HOME/bin/provision-env-1password"
  "bin/update-ai-tools:$HOME/bin/update-ai-tools"
)

LEGACY_BIN_LINKS=(
  "$HOME/bin/sync-dotfiles"
  "$HOME/bin/sync-agents"
  "$HOME/bin/sync-skills"
  "$HOME/bin/sync-op"
  "$HOME/bin/upgrade-ai-tools"
)

canonical_path() {
  local path="$1"
  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  (cd -P "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base")
}

link_target_path() {
  local link_path="$1"
  local target="$2"

  if [[ "$target" = /* ]]; then
    canonical_path "$target"
  else
    canonical_path "$(dirname "$link_path")/$target"
  fi
}

make_link() {
  local src_full="$1"
  local dst_full="$2"
  local label="$3"

  if [[ ! -e "$src_full" ]]; then
    warn "source missing, skip: ${src_full#$DOTFILES/}"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  mkdir -p "$(dirname "$dst_full")"

  if [[ -L "$dst_full" ]]; then
    local cur cur_resolved src_resolved
    cur=$(readlink "$dst_full")
    cur_resolved=$(link_target_path "$dst_full" "$cur" || true)
    src_resolved=$(canonical_path "$src_full")
    if [[ "$cur_resolved" = "$src_resolved" ]]; then
      return
    fi
    warn "retarget: $label was → $cur"
    rm "$dst_full"
    if ln -s "$src_full" "$dst_full"; then
      ok "$label → $src_full"
      RETARGETED=$((RETARGETED + 1))
    else
      fail "ln failed: $label"
      FAILED=$((FAILED + 1))
    fi
    return
  fi

  if [[ -e "$dst_full" ]]; then
    warn "skip: $label exists as a real file or dir"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  if ln -s "$src_full" "$dst_full"; then
    ok "$label → $src_full"
    LINKED=$((LINKED + 1))
  else
    fail "ln failed: $label"
    FAILED=$((FAILED + 1))
  fi
}

remove_legacy_link() {
  local dst_full="$1"
  local cur cur_resolved

  [[ -L "$dst_full" ]] || return 0
  cur=$(readlink "$dst_full")
  cur_resolved=$(link_target_path "$dst_full" "$cur" || true)
  case "$cur_resolved" in
    "$DOTFILES"/bin/*)
      if rm "$dst_full"; then
        ok "removed legacy helper link: ${dst_full#$HOME/}"
        REMOVED=$((REMOVED + 1))
      else
        fail "rm failed: ${dst_full#$HOME/}"
        FAILED=$((FAILED + 1))
      fi
      ;;
  esac
}

[[ -d "$DOTFILES" ]] || { fail "$DOTFILES not found"; exit 1; }

info "Linking dotfiles"
for link in "${DOTFILE_LINKS[@]}"; do
  src="${link%%:*}"
  dst="${link#*:}"
  make_link "$DOTFILES/$src" "$dst" "${dst#$HOME/}"
done

echo
info "Linking helper commands"
for link in "${BIN_LINKS[@]}"; do
  src="${link%%:*}"
  dst="${link#*:}"
  make_link "$DOTFILES/$src" "$dst" "${dst#$HOME/}"
done

echo
info "Removing old helper command names"
for link in "${LEGACY_BIN_LINKS[@]}"; do
  remove_legacy_link "$link"
done

echo
echo "summary: linked=$LINKED retargeted=$RETARGETED removed=$REMOVED skipped=$SKIPPED failed=$FAILED"
[[ $FAILED -eq 0 ]] && ok "dotfiles links complete" || { fail "some links failed"; exit 1; }
