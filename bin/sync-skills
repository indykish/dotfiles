#!/usr/bin/env bash
# sync-skills — sync gstack + dotfiles skills into ~/Projects/dotfiles/gstack
set -e

DOTFILES="$HOME/Projects/dotfiles"
DOTFILES_SKILLS="$DOTFILES/skills"
GSTACK="$DOTFILES/gstack"
REPO="git@github.com:garrytan/gstack.git"

AGENTS=(
  "$HOME/.claude"
  "$HOME/.codex"
  "$HOME/.agents"
  "$HOME/.amp"
  "$HOME/.opencode"
)

ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }

# 1. Remove and re-clone gstack into dotfiles/gstack (clean slate)
rm -rf "$GSTACK"
git clone "$REPO" "$GSTACK"
ok "Cloned gstack to $GSTACK"

# 2. Copy dotfiles skills into gstack (e.g., handoff, pickup, write-unit-test)
for skill_dir in "$DOTFILES_SKILLS"/*/; do
  [ -d "$skill_dir" ] || continue
  skill_name="$(basename "$skill_dir")"
  mkdir -p "$GSTACK/$skill_name"
  cp -r "$skill_dir"* "$GSTACK/$skill_name/"
  ok "Dotfiles skill: $skill_dir → $GSTACK/$skill_name"
done

# 3. Symlink agent configs → dotfiles/gstack and dotfiles/AGENTS.md
for agent_dir in "${AGENTS[@]}"; do
  mkdir -p "$agent_dir"

  # skills/ → ~/Projects/dotfiles/gstack
  rm -rf "$agent_dir/skills"
  ln -snf "$GSTACK" "$agent_dir/skills"
  ok "Linked $agent_dir/skills → $GSTACK"

  # For Claude: CLAUDE.md → ~/Projects/dotfiles/AGENTS.md
  # For others: AGENTS.md → ~/Projects/dotfiles/AGENTS.md
  agent_name="$(basename "$agent_dir")"
  if [ "$agent_name" = ".claude" ]; then
    rm -f "$agent_dir/CLAUDE.md"
    ln -snf "$DOTFILES/AGENTS.md" "$agent_dir/CLAUDE.md"
    ok "Linked $agent_dir/CLAUDE.md → $DOTFILES/AGENTS.md"
  else
    rm -f "$agent_dir/AGENTS.md"
    ln -snf "$DOTFILES/AGENTS.md" "$agent_dir/AGENTS.md"
    ok "Linked $agent_dir/AGENTS.md → $DOTFILES/AGENTS.md"
  fi
done

ok "Skills synced."
