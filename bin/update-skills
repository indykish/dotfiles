#!/usr/bin/env bash
# update-skills — install gstack, then generate one symlink overlay for all agents.
set -euo pipefail

DOTFILES="$HOME/Projects/dotfiles"
DOTFILES_SKILLS="$DOTFILES/skills"
UNIFIED_SKILLS="$DOTFILES/.unified-skills"
SYSTEM_SKILLS="$UNIFIED_SKILLS/.system"
GSTACK_DIR="$HOME/.local/share/gstack"
GSTACK_REPO="https://github.com/garrytan/gstack.git"

# Agent configurations: "host_flag:config_dir:skills_subdir"
# skills_subdir is relative to config_dir.
AGENTS=(
    "claude:$HOME/.claude:skills"
    "codex:$HOME/.codex:skills"
    "opencode:$HOME/.config/opencode:skills"
    "amp:$HOME/.amp:skills"
)

ok()   { printf '\033[32m✔\033[0m %s\n' "$1"; }
info() { printf '\033[34mℹ\033[0m %s\n' "$1"; }
warn() { printf '\033[33m⚠\033[0m %s\n' "$1"; }
fail() { printf '\033[31m✖\033[0m %s\n' "$1"; exit 1; }

usage() {
    cat <<'EOF'
update-skills — update gstack, rebuild the unified skills overlay, and link it
into Claude, Codex, OpenCode, and Amp.

Usage: update-skills [--doctor]

Also links OpenCode config and the generated global instructions for each
installed agent.
--doctor verifies the generated overlay and installed agent links only.
EOF
}

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
    --doctor) DOCTOR_ONLY=1 ;;
    *) DOCTOR_ONLY=0 ;;
esac

link_skill_dir() {
    local source_dir="$1"
    local skill_name
    skill_name="$(basename "$source_dir")"

    [ "$skill_name" != "gstack" ] || return 0
    [ -f "$source_dir/SKILL.md" ] || return 0

    rm -f "$OVERLAY_TMP/$skill_name"
    ln -snf "$source_dir" "$OVERLAY_TMP/$skill_name"
    ok "Skill link: $skill_name → $source_dir"
}

doctor_file() {
    local path="$1"
    [ -f "$path" ] || fail "Missing required file: $path"
    ok "Found $path"
}

doctor_executable() {
    local path="$1"
    [ -x "$path" ] || fail "Missing executable helper: $path"
    ok "Executable $path"
}

doctor_overlay() {
    local target stale_entry

    target="$(readlink "$UNIFIED_SKILLS/gstack" 2>/dev/null || true)"
    [ "$target" = "$GSTACK_DIR" ] || fail "$UNIFIED_SKILLS/gstack must link to $GSTACK_DIR (got: ${target:-missing})"
    ok "$UNIFIED_SKILLS/gstack → $GSTACK_DIR"

    for agent_config in "${AGENTS[@]}"; do
        IFS=':' read -r _host_flag config_dir skills_subdir <<< "$agent_config"
        [ -d "$config_dir" ] || continue

        target="$(readlink "$config_dir/$skills_subdir" 2>/dev/null || true)"
        [ "$target" = "$UNIFIED_SKILLS" ] || fail "$config_dir/$skills_subdir must link to $UNIFIED_SKILLS (got: ${target:-missing})"
        ok "$config_dir/$skills_subdir → $UNIFIED_SKILLS"
    done

    doctor_executable "$HOME/.claude/skills/gstack/browse/dist/browse"
    doctor_executable "$HOME/.claude/skills/gstack/design/dist/design"
    doctor_executable "$HOME/.claude/skills/gstack/make-pdf/dist/pdf"
    doctor_file "$HOME/.claude/skills/design-shotgun/SKILL.md"
    doctor_file "$HOME/.claude/skills/kishore-spec-new/SKILL.md"

    if [ -e "$SYSTEM_SKILLS" ] || [ -L "$SYSTEM_SKILLS" ]; then
        [ -d "$SYSTEM_SKILLS" ] || fail "Reserved system skills entry must be a directory: $SYSTEM_SKILLS"
        ok "Reserved agent-managed system skills directory: $SYSTEM_SKILLS"
    fi

    stale_entry="$(find "$UNIFIED_SKILLS" -mindepth 1 -maxdepth 1 ! -type l ! -path "$SYSTEM_SKILLS" -print -quit)"
    [ -z "$stale_entry" ] || fail "Unexpected non-symlink entry in generated overlay: $stale_entry"
    ok "No copied GStack tree remains in $UNIFIED_SKILLS"
}

# ─── Playwright Chromium (curl fallback) ──────────────────────────────
# gstack's ./setup installs Chromium via 'bunx playwright install chromium',
# which hangs: both bun and node receive all bytes from the Playwright Content
# Delivery Network (CDN) then stall on HTTP/2 stream completion because the
# final frame never arrives. curl fetches the same zips reliably.
# ensure_playwright_chromium runs once so all host setups skip the download.
pw_can_launch() {
    if command -v bun >/dev/null 2>&1; then
        ( cd "$GSTACK_DIR" && bun --eval 'import { chromium } from "playwright"; const b = await chromium.launch(); await b.close();' ) >/dev/null 2>&1
    elif command -v node >/dev/null 2>&1; then
        ( cd "$GSTACK_DIR" && node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" ) >/dev/null 2>&1
    else
        return 2
    fi
}

_pw_json_get() {
    bun -e "const j=require('$BROWSERS_JSON'); const c=j.browsers.find(b=>b.name==='$1'); process.stdout.write(String(c.$2))"
}

pw_install_zip() {
    local label="$1" url="$2" dest="$3" tmp
    tmp="$(mktemp "${TMPDIR:-/tmp}/pwcurl.XXXXXX")"
    info "Fetching $label via curl..."
    if ! curl -fL --retry 3 --retry-delay 2 --max-time 280 -o "$tmp" "$url"; then
        rm -f "$tmp"
        warn "curl failed: $url"
        return 1
    fi
    rm -rf "$dest"
    mkdir -p "$dest"
    ( cd "$dest" && unzip -q -o "$tmp" )
    rm -f "$tmp"
    ok "$label installed ($(du -sh "$dest" 2>/dev/null | cut -f1))"
}

# Heal Playwright Chromium via curl when the launch check fails. No-op (ok) when
# the browser already launches, so normal runs pay only one quick launch check.
ensure_playwright_chromium() {
    BROWSERS_JSON="$GSTACK_DIR/node_modules/playwright-core/browsers.json"
    if [ ! -f "$BROWSERS_JSON" ] || [ ! -d "$GSTACK_DIR/node_modules/playwright" ]; then
        warn "playwright not installed in gstack yet; skipping curl preflight (setup will install)"
        return 0
    fi
    if pw_can_launch; then
        ok "Playwright Chromium launches OK; gstack setup will skip download"
        return 0
    fi
    warn "Playwright Chromium missing/broken — running curl fallback"

    local meta_rev meta_ver cache_dir pf_dir chrome_zip shell_zip base
    meta_rev="$(_pw_json_get chromium revision)"
    meta_ver="$(_pw_json_get chromium browserVersion)"
    [ -n "$meta_rev" ] && [ -n "$meta_ver" ] || { warn "could not parse browsers.json; skipping"; return 1; }

    if [ -n "${PLAYWRIGHT_BROWSERS_PATH:-}" ]; then
        cache_dir="$PLAYWRIGHT_BROWSERS_PATH"
    elif [ "$(uname -s)" = "Darwin" ]; then
        cache_dir="$HOME/Library/Caches/ms-playwright"
    else
        cache_dir="$HOME/.cache/ms-playwright"
    fi

    case "$(uname -s)/$(uname -m)" in
        Darwin/arm64)  pf_dir="mac-arm64"; chrome_zip="chrome-mac-arm64.zip";          shell_zip="chrome-headless-shell-mac-arm64.zip" ;;
        Darwin/x86_64) pf_dir="mac-x64";   chrome_zip="chrome-mac-x64.zip";            shell_zip="chrome-headless-shell-mac-x64.zip" ;;
        *) warn "curl fallback supports Darwin only; gstack setup will try bunx (timeout-capped)"; return 1 ;;
    esac
    command -v unzip >/dev/null 2>&1 || { warn "unzip required but not installed"; return 1; }

    base="https://cdn.playwright.dev/builds/cft/$meta_ver/$pf_dir"
    info "Installing Playwright Chromium $meta_ver (revision $meta_rev) via curl into $cache_dir"
    pw_install_zip "chromium ($meta_ver)"             "$base/$chrome_zip" "$cache_dir/chromium-$meta_rev"             || return 1
    pw_install_zip "chromium-headless-shell ($meta_ver)" "$base/$shell_zip" "$cache_dir/chromium_headless_shell-$meta_rev" || return 1

    if pw_can_launch; then
        ok "Playwright Chromium ready (curl fallback)"
        return 0
    fi
    warn "Files installed but launch check failed — inspect $cache_dir"
    return 1
}

if [ "$DOCTOR_ONLY" -eq 1 ]; then
    doctor_overlay
    "$DOTFILES/bin/oracle-rules" link-agent-homes --check
    ok "Skills doctor passed"
    exit 0
fi

command -v bun >/dev/null 2>&1 || fail "bun is required; install it before running update-skills"
GSTACK_TIMEOUT_BIN="$(command -v timeout || command -v gtimeout || true)"
[ -n "$GSTACK_TIMEOUT_BIN" ] || fail "timeout or gtimeout is required; install GNU coreutils before running update-skills"

# 1. Clone or update gstack in its standard user-data location.
info "Installing gstack to $GSTACK_DIR..."
if [ -d "$GSTACK_DIR/.git" ]; then
    cd "$GSTACK_DIR" && git pull --ff-only
    ok "Updated gstack"
else
    rm -rf "$GSTACK_DIR"
    git clone --single-branch --depth 1 "$GSTACK_REPO" "$GSTACK_DIR"
    ok "Cloned gstack"
fi

# 2. Run gstack's proper setup for each installed agent
info "Running gstack setup for detected agents..."
cd "$GSTACK_DIR"

# Install package dependencies before the browser preflight. A fresh clone has
# no Playwright metadata yet, and gstack setup would otherwise reach its hanging
# bunx browser download before this script could apply the curl fallback.
bun install --frozen-lockfile 2>/dev/null || bun install

# Ensure Playwright Chromium is usable BEFORE the per-agent ./setup loop, so a
# missing/half-installed browser — or the bun/node CDN stream-completion hang —
# can't stall setup. See ensure_playwright_chromium for the curl fallback. The
# 600s timeout on each ./setup below is the backstop.
ensure_playwright_chromium || warn "curl preflight failed; gstack setup may re-attempt (capped by timeout below)"

for agent_config in "${AGENTS[@]}"; do
    IFS=':' read -r host_flag config_dir skills_subdir <<< "$agent_config"
    
    # Skip if agent not installed
    if [ ! -d "$config_dir" ]; then
        info "Skipping $host_flag (not installed)"
        continue
    fi

    if [ "$host_flag" = "amp" ]; then
        info "Skipping gstack setup for amp (upstream setup has no amp host; unified overlay handles skills)"
        continue
    fi
    
    # Run gstack's proper setup for this agent.
    # Cap with timeout so a hung Playwright Chromium download (bun/node stall on
    # the CDN's HTTP/2 stream completion) can't block update-ai-tools forever;
    # the warn branch below lets the rest of the flow continue on bounded failure.
    info "Setting up gstack for $host_flag..."
    GSTACK_TIMEOUT=600
    if "$GSTACK_TIMEOUT_BIN" "$GSTACK_TIMEOUT" ./setup --host "$host_flag"; then
        ok "gstack setup complete for $host_flag"
    else
        rc=$?
        warn "gstack setup failed for $host_flag (exit ${rc}; timed out after ${GSTACK_TIMEOUT}s if rc=124)"
    fi
done

# 3. Create unified skills directory with gstack + custom dotfiles skills.
info "Creating unified skills symlink overlay..."
OVERLAY_TMP="$(mktemp -d "$DOTFILES/.unified-skills.tmp.XXXXXX")"
cleanup() {
    if [ -n "${OVERLAY_TMP:-}" ] && [ -d "$OVERLAY_TMP" ]; then
        rm -rf "$OVERLAY_TMP"
    fi
}
trap cleanup EXIT

ln -snf "$GSTACK_DIR" "$OVERLAY_TMP/gstack"
ok "Helper root link: gstack → $GSTACK_DIR"

# Expose every upstream GStack skill as a flat symlink for agent discovery.
for skill_dir in "$GSTACK_DIR"/*/; do
    [ -d "$skill_dir" ] || continue
    link_skill_dir "${skill_dir%/}"
done
for skill_dir in "$GSTACK_DIR"/browser-skills/*/ "$GSTACK_DIR"/openclaw/skills/*/; do
    [ -d "$skill_dir" ] || continue
    link_skill_dir "${skill_dir%/}"
done

# Overlay dotfiles custom skills last; they take precedence on name collisions.
for skill_dir in "$DOTFILES_SKILLS"/*/; do
    [ -d "$skill_dir" ] || continue
    skill_name="$(basename "$skill_dir")"

    rm -f "$OVERLAY_TMP/$skill_name"
    ln -snf "$skill_dir" "$OVERLAY_TMP/$skill_name"
    ok "Dotfiles skill overlay: $skill_name → $skill_dir"
done

rm -rf "$UNIFIED_SKILLS"
mv "$OVERLAY_TMP" "$UNIFIED_SKILLS"
OVERLAY_TMP=""

# 4. Symlink all agents to unified skills directory
info "Symlinking agent skills to unified directory..."
for agent_config in "${AGENTS[@]}"; do
    IFS=':' read -r host_flag config_dir skills_subdir <<< "$agent_config"
    
    # Skip if agent not installed
    [ -d "$config_dir" ] || continue
    
    agent_skills_dir="$config_dir/$skills_subdir"
    
    # Backup existing skills if not a symlink
    if [ -d "$agent_skills_dir" ] && [ ! -L "$agent_skills_dir" ]; then
        backup_dir="${agent_skills_dir}.backup.$(date +%Y%m%d_%H%M%S)"
        mv "$agent_skills_dir" "$backup_dir"
        warn "Backed up existing skills to $backup_dir"
    fi
    
    # Remove existing symlink or backed-up directory and create the unified symlink.
    rm -rf "$agent_skills_dir"
    ln -snf "$UNIFIED_SKILLS" "$agent_skills_dir"
    ok "Linked $agent_skills_dir → $UNIFIED_SKILLS"
    
done

"$DOTFILES/bin/oracle-rules" render \
    --profile global \
    --output "$DOTFILES/oracle-rules/generated/global" >/dev/null
"$DOTFILES/bin/oracle-rules" link-agent-homes

# 5. Link opencode.json config (XDG Base Directory location)
info "Linking opencode.json..."
OPENCODE_CONFIG_SRC="$DOTFILES/.config/opencode/opencode.json"
OPENCODE_CONFIG_DST="$HOME/.config/opencode/opencode.json"
if [ -f "$OPENCODE_CONFIG_SRC" ]; then
    if [ -f "$OPENCODE_CONFIG_DST" ] && [ ! -L "$OPENCODE_CONFIG_DST" ]; then
        backup_file="${OPENCODE_CONFIG_DST}.backup.$(date +%Y%m%d_%H%M%S)"
        cp "$OPENCODE_CONFIG_DST" "$backup_file"
        warn "Backed up existing opencode.json to $backup_file"
    fi
    rm -f "$OPENCODE_CONFIG_DST"
    ln -snf "$OPENCODE_CONFIG_SRC" "$OPENCODE_CONFIG_DST"
    ok "Linked $OPENCODE_CONFIG_DST → $OPENCODE_CONFIG_SRC"
else
    warn "Source opencode.json not found at $OPENCODE_CONFIG_SRC"
fi

info "Running skills doctor..."
doctor_overlay

ok "Skills updated! All agents now use unified skills from $UNIFIED_SKILLS"
info "Gstack installed at: $GSTACK_DIR"
info "Unified skills at: $UNIFIED_SKILLS"
