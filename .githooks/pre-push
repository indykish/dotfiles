#!/usr/bin/env bash
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

echo "pre-push: running deterministic governance audit" >&2
make audit || exit 1

semantic_change=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "$local_sha" || "$local_sha" = "0000000000000000000000000000000000000000" ]] && continue
  if [[ "$remote_sha" = "0000000000000000000000000000000000000000" ]]; then
    files="$(git log --name-only --pretty=format: "$local_sha")"
  else
    files="$(git diff --name-only "$remote_sha..$local_sha")"
  fi
  if grep -qE '^(orly/(core|packs|profiles|src)/|orly/(registry|repositories)\.json|AGENTS\.md|SOUL\.md|dispatch/.*\.md|audits/agents-md\.md|evals/llms/fixtures\.jsonl|docs/(EXECUTE_DOC_READS|ORLY_ARCHITECTURE|HARNESS_VERIFY_OUTPUT)\.md|\.githooks/(pre-commit|pre-push)|Makefile)$' <<<"$files"; then
    semantic_change=1
  fi
done

if [[ $semantic_change -eq 1 ]]; then
  if [[ "${SKIP_INVARIANCE_PUSH:-0}" = "1" ]]; then
    echo "pre-push: user override skips live comprehension; record the reason in the newest commit" >&2
    llm_result="not-required"
  else
    echo "pre-push: semantic governance changed — running live comprehension smoke test" >&2
    make llmevals SMOKE=1 || exit 1
    llm_result="pass"
  fi
else
  llm_result="not-required"
fi

bin/orly verify --all --write-evidence --llm-result "$llm_result" || exit 1
exit 0
